import json
import self.wasm_rt

// --- wt_http_request ---

test "wt_http_request: GET httpbin" {
  let resp = wasm_rt.wt_http_request("GET", "https://httpbin.org/ip", "{}", "")!
  let parsed = json.parse(resp)
  match parsed {
    ok(v) => {
      let status = json.get_int(v, "status") ?? 0
      assert_eq(status, 200)
    },
    err(_) => assert(false),
  }
}

test "wt_http_request: invalid URL" {
  let resp = wasm_rt.wt_http_request("GET", "http://invalid.invalid.invalid", "{}", "")!
  let parsed = json.parse(resp)
  match parsed {
    ok(v) => {
      let error = json.get_string(v, "error") ?? ""
      assert(string.len(error) > 0)
    },
    err(_) => assert(false),
  }
}

// --- wt_exec_command ---

test "wt_exec_command: echo" {
  let resp = wasm_rt.wt_exec_command("echo", "[\"hello\"]", ".")!
  let parsed = json.parse(resp)
  match parsed {
    ok(v) => {
      let exit_code = json.get_int(v, "exit_code") ?? -1
      assert_eq(exit_code, 0)
      let stdout = json.get_string(v, "stdout") ?? ""
      assert(string.len(stdout) > 0)
    },
    err(_) => assert(false),
  }
}

test "wt_exec_command: invalid command" {
  let resp = wasm_rt.wt_exec_command("nonexistent_command_xyz", "[]", ".")!
  let parsed = json.parse(resp)
  match parsed {
    ok(v) => {
      let error = json.get_string(v, "error") ?? ""
      assert(string.len(error) > 0)
    },
    err(_) => assert(false),
  }
}

// --- wt_inspect ---

test "wt_inspect: demo agent or missing" {
  let resp = wasm_rt.wt_inspect("examples/demo-agent/src/mod.wasm")
  let parsed = json.parse(resp)
  match parsed {
    ok(v) => {
      let error = json.get_string(v, "error") ?? ""
      if error != "" then assert(true) // file not found in CI — ok
      else {
        let imports = json.get_array(v, "imports") ?? []
        let exports = json.get_array(v, "exports") ?? []
        assert(list.len(imports) > 0)
        assert(list.len(exports) > 0)
      }
    },
    err(_) => assert(false),
  }
}

test "wt_inspect: invalid path" {
  let resp = wasm_rt.wt_inspect("nonexistent.wasm")
  let parsed = json.parse(resp)
  match parsed {
    ok(v) => {
      let error = json.get_string(v, "error") ?? ""
      assert(string.len(error) > 0)
    },
    err(_) => assert(false),
  }
}

// --- build_sandbox_profile ---

test "build_sandbox_profile: empty allowed_net means network open" {
  let profile = wasm_rt.build_sandbox_profile(["."], [])
  assert(not string.contains(profile, "(deny network-outbound)"))
}

test "build_sandbox_profile: allow_net restricts to listed ports" {
  let profile = wasm_rt.build_sandbox_profile(["."], ["*:443"])
  assert(string.contains(profile, "(deny network-outbound)"))
  assert(string.contains(profile, "(allow network-outbound (local udp))"))
}

test "build_sandbox_profile: allowed_net adds port-based TCP rules" {
  // sandbox-exec only supports * or localhost as host — port filtering only
  let profile = wasm_rt.build_sandbox_profile(["."], ["api.example.com:443"])
  assert(string.contains(profile, "(allow network-outbound (remote tcp \"*:443\"))"))
}

test "build_sandbox_profile: wildcard port" {
  let profile = wasm_rt.build_sandbox_profile(["."], ["*:*"])
  assert(string.contains(profile, "(allow network-outbound (remote tcp \"*:*\"))"))
}

test "build_sandbox_profile: :ro mount has no file-write rule" {
  let profile = wasm_rt.build_sandbox_profile(["/workspace:ro"], [])
  assert(not string.contains(profile, "(allow file-write* (subpath \"/workspace\"))"))
}

test "build_sandbox_profile: writable mount has file-write rule" {
  let profile = wasm_rt.build_sandbox_profile(["/workspace"], [])
  assert(string.contains(profile, "(allow file-write* (subpath \"/workspace\"))"))
}

test "build_sandbox_profile: cryptographic keys denied" {
  let profile = wasm_rt.build_sandbox_profile(["."], [])
  assert(string.contains(profile, ".ssh"))
  assert(string.contains(profile, ".gnupg"))
  assert(not string.contains(profile, ".aws"))
  assert(not string.contains(profile, "Documents"))
}

// --- wt_getpid ---

test "wt_getpid: returns positive" {
  let pid = wasm_rt.wt_getpid()
  assert(pid > 0)
}

// --- wt_home_dir ---

test "wt_home_dir: returns non-empty" {
  let home = wasm_rt.wt_home_dir()
  assert(string.len(home) > 0)
}
