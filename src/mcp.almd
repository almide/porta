// MCP Protocol State Machine

import json
import self.jsonrpc
import self.manifest
import self.dispatch
import self.observability
import self.wasm_rt

type McpState =
  | Initializing
  | Ready
  | Closed

type McpServer = {
  state: McpState,
  manifest: manifest.Manifest,
  config: dispatch.InstanceConfig,
  metrics: observability.Metrics,
}

fn new_server(m: manifest.Manifest, config: dispatch.InstanceConfig) -> McpServer =
  {state: Initializing, manifest: m, config: config, metrics: observability.empty_metrics()}

// --- Handle a single request ---

effect fn handle_request(server: McpServer, req: jsonrpc.JsonRpcRequest) -> Result[{server: McpServer, response: Option[String]}, String] =
  match req.method {
    "initialize" => handle_initialize(server, req),
    "notifications/initialized" => ok({server: {...server, state: Ready}, response: none}),
    "tools/list" => handle_tools_list(server, req),
    "tools/call" => handle_tools_call(server, req),
    "resources/list" => handle_resources_list(server, req),
    "resources/read" => handle_resources_read(server, req),
    "prompts/list" => handle_prompts_list(server, req),
    "prompts/get" => handle_prompts_get(server, req),
    "ping" => ok({server: server, response: some(jsonrpc.make_response(req.id, json.object([])))}),
    _ => ok({server: server, response: some(jsonrpc.make_error_response(req.id, -32601, "Method not found: ${req.method}"))}),
  }

effect fn handle_initialize(server: McpServer, req: jsonrpc.JsonRpcRequest) -> Result[{server: McpServer, response: Option[String]}, String] = {
  let result = json.object([
    ("protocolVersion", json.from_string("2025-03-26")),
    ("serverInfo", json.object([
      ("name", json.from_string("porta/${server.manifest.name}")),
      ("version", json.from_string(server.manifest.version)),
    ])),
    ("capabilities", json.object([
      ("tools", json.object([("listChanged", json.from_bool(false))])),
      ("resources", json.object([("listChanged", json.from_bool(false))])),
      ("prompts", json.object([("listChanged", json.from_bool(false))])),
    ])),
  ])
  ok({server: server, response: some(jsonrpc.make_response(req.id, result))})
}

effect fn handle_tools_list(server: McpServer, req: jsonrpc.JsonRpcRequest) -> Result[{server: McpServer, response: Option[String]}, String] = {
  let agent_tools = server.manifest.tools |> list.map((tool) =>
    json.object([
      ("name", json.from_string(tool.name)),
      ("description", json.from_string(tool.description)),
      ("inputSchema", tool.input_schema),
    ])
  )
  let builtin_tools = [
    json.object([
      ("name", json.from_string("porta.exec")),
      ("description", json.from_string("Execute a shell command in the sandbox")),
      ("inputSchema", json.object([
        ("type", json.from_string("object")),
        ("properties", json.object([
          ("command", json.object([("type", json.from_string("string")), ("description", json.from_string("Command to execute"))])),
          ("args", json.object([("type", json.from_string("array")), ("items", json.object([("type", json.from_string("string"))])), ("description", json.from_string("Command arguments"))])),
          ("cwd", json.object([("type", json.from_string("string")), ("description", json.from_string("Working directory"))])),
        ])),
        ("required", json.array([json.from_string("command")])),
      ])),
    ]),
    json.object([
      ("name", json.from_string("porta.http")),
      ("description", json.from_string("Make an HTTP request")),
      ("inputSchema", json.object([
        ("type", json.from_string("object")),
        ("properties", json.object([
          ("method", json.object([("type", json.from_string("string")), ("description", json.from_string("HTTP method: GET, POST, PUT, DELETE"))])),
          ("url", json.object([("type", json.from_string("string")), ("description", json.from_string("Request URL"))])),
          ("headers", json.object([("type", json.from_string("object")), ("description", json.from_string("Request headers"))])),
          ("body", json.object([("type", json.from_string("string")), ("description", json.from_string("Request body"))])),
        ])),
        ("required", json.array([json.from_string("method"), json.from_string("url")])),
      ])),
    ]),
  ]
  let all_tools = agent_tools + builtin_tools
  let result = json.object([("tools", json.array(all_tools))])
  ok({server: server, response: some(jsonrpc.make_response(req.id, result))})
}

effect fn handle_tools_call(server: McpServer, req: jsonrpc.JsonRpcRequest) -> Result[{server: McpServer, response: Option[String]}, String] = {
  let tool_name = json.get_string(req.params, "name") ?? ""
  let arguments = json.get(req.params, "arguments") ?? json.object([])

  // Built-in tools
  if tool_name == "porta.exec" then {
    let result = handle_builtin_exec(arguments)
    ok({server: server, response: some(jsonrpc.make_response(req.id, result))})
  }
  else if tool_name == "porta.http" then {
    let result = handle_builtin_http(arguments)
    ok({server: server, response: some(jsonrpc.make_response(req.id, result))})
  }
  else {

  let tool = server.manifest.tools |> list.find((t) => t.name == tool_name)
  match tool {
    none => {
      let avail = server.manifest.tools |> list.map((t) => t.name) |> string.join(", ")
      let resp = jsonrpc.make_error_response(req.id, -32602, "Unknown tool: '${tool_name}'. Available tools: ${avail}")
      ok({server: server, response: some(resp)})
    },
    some(_t) => {
      let args_json = json.stringify(arguments)
      let tool_result = dispatch.dispatch_tool(server.config, tool_name, args_json)!

      // Diagnostic log to stderr
      let success = match tool_result.exit_code { some(c) => c == 0, none => true }
      eprintln(observability.format_tool_log(tool_name, tool_result.metrics.steps, tool_result.metrics.memory_pages, success))
      let updated_metrics = observability.merge_tool_call(server.metrics, tool_result.metrics.steps, tool_result.metrics.memory_pages)
      let server = {...server, metrics: updated_metrics}

      // Parse stdout: expect {"ok": ...} or {"err": ...}
      let output = tool_result.stdout
      let parsed = json.parse(output)
      let result = match parsed {
        ok(v) => {
          let ok_val = json.get(v, "ok")
          let err_val = json.get(v, "err")
          match ok_val {
            some(ov) => json.object([
              ("content", json.array([
                json.object([
                  ("type", json.from_string("text")),
                  ("text", match json.as_string(ov) { some(s) => json.from_string(s), none => ov }),
                ]),
              ])),
              ("isError", json.from_bool(false)),
            ]),
            none => match err_val {
              some(ev) => json.object([
                ("content", json.array([
                  json.object([
                    ("type", json.from_string("text")),
                    ("text", match json.as_string(ev) { some(s) => json.from_string(s), none => ev }),
                  ]),
                ])),
                ("isError", json.from_bool(true)),
              ]),
              none => json.object([
                ("content", json.array([
                  json.object([
                    ("type", json.from_string("text")),
                    ("text", json.from_string(output)),
                  ]),
                ])),
                ("isError", json.from_bool(false)),
              ]),
            },
          }
        },
        err(_) => {
          // Raw text output (not JSON)
          json.object([
            ("content", json.array([
              json.object([
                ("type", json.from_string("text")),
                ("text", json.from_string(output)),
              ]),
            ])),
            ("isError", json.from_bool(false)),
          ])
        },
      }
      ok({server: server, response: some(jsonrpc.make_response(req.id, result))})
    },
  }
  } // else (not builtin)
}

// --- Built-in tools ---

fn handle_builtin_exec(args: Value) -> Value = {
  let cmd = json.get_string(args, "command") ?? ""
  let cmd_args = json.get_array(args, "args") ?? []
  let args_strs = cmd_args |> list.filter_map((a) => json.as_string(a))
  let cwd = json.get_string(args, "cwd") ?? "."
  let args_json = json.stringify(json.array(args_strs |> list.map(json.from_string)))
  let result_json = wasm_rt.wt_exec_command(cmd, args_json, cwd)
  let parsed = json.parse(result_json)
  match parsed {
    ok(v) => {
      let stdout = json.get_string(v, "stdout") ?? ""
      let stderr = json.get_string(v, "stderr") ?? ""
      let error = json.get_string(v, "error") ?? ""
      let output = if error != "" then error
        else if stderr != "" then stdout + "\n--- stderr ---\n" + stderr
        else stdout
      json.object([
        ("content", json.array([json.object([("type", json.from_string("text")), ("text", json.from_string(output))])])),
        ("isError", json.from_bool(error != "")),
      ])
    },
    err(_) => json.object([
      ("content", json.array([json.object([("type", json.from_string("text")), ("text", json.from_string(result_json))])])),
      ("isError", json.from_bool(true)),
    ]),
  }
}

fn handle_builtin_http(args: Value) -> Value = {
  let method = json.get_string(args, "method") ?? "GET"
  let url = json.get_string(args, "url") ?? ""
  let headers = json.get(args, "headers") ?? json.object([])
  let body = json.get_string(args, "body") ?? ""
  let headers_json = json.stringify(headers)
  let result_json = wasm_rt.wt_http_request(method, url, headers_json, body)
  let parsed = json.parse(result_json)
  match parsed {
    ok(v) => {
      let body_text = json.get_string(v, "body") ?? ""
      let error = json.get_string(v, "error") ?? ""
      let output = if error != "" then error else body_text
      json.object([
        ("content", json.array([json.object([("type", json.from_string("text")), ("text", json.from_string(output))])])),
        ("isError", json.from_bool(error != "")),
      ])
    },
    err(_) => json.object([
      ("content", json.array([json.object([("type", json.from_string("text")), ("text", json.from_string(result_json))])])),
      ("isError", json.from_bool(true)),
    ]),
  }
}

// --- Resources ---

effect fn handle_resources_list(server: McpServer, req: jsonrpc.JsonRpcRequest) -> Result[{server: McpServer, response: Option[String]}, String] = {
  let resources_json = server.manifest.resources |> list.map((r) =>
    json.object([
      ("uri", json.from_string(r.uri)),
      ("name", json.from_string(r.name)),
      ("description", json.from_string(r.description)),
      ("mimeType", json.from_string(r.mime_type)),
    ])
  )
  let result = json.object([("resources", json.array(resources_json))])
  ok({server: server, response: some(jsonrpc.make_response(req.id, result))})
}

effect fn handle_resources_read(server: McpServer, req: jsonrpc.JsonRpcRequest) -> Result[{server: McpServer, response: Option[String]}, String] = {
  let uri = json.get_string(req.params, "uri") ?? ""
  let resource = server.manifest.resources |> list.find((r) => r.uri == uri)
  match resource {
    none => {
      let resp = jsonrpc.make_error_response(req.id, -32602, "Unknown resource: '${uri}'")
      ok({server: server, response: some(resp)})
    },
    some(r) => {
      let args_json = json.stringify(json.object([("uri", json.from_string(uri))]))
      let tool_result = dispatch.dispatch_tool(server.config, "_resource_read", args_json)!
      let content = json.object([
        ("contents", json.array([
          json.object([
            ("uri", json.from_string(uri)),
            ("mimeType", json.from_string(r.mime_type)),
            ("text", json.from_string(tool_result.stdout)),
          ]),
        ])),
      ])
      ok({server: server, response: some(jsonrpc.make_response(req.id, content))})
    },
  }
}

// --- Prompts ---

effect fn handle_prompts_list(server: McpServer, req: jsonrpc.JsonRpcRequest) -> Result[{server: McpServer, response: Option[String]}, String] = {
  let prompts_json = server.manifest.prompts |> list.map((p) => {
    let args_json = p.arguments |> list.map((a) =>
      json.object([
        ("name", json.from_string(a.name)),
        ("description", json.from_string(a.description)),
        ("required", json.from_bool(a.required)),
      ])
    )
    json.object([
      ("name", json.from_string(p.name)),
      ("description", json.from_string(p.description)),
      ("arguments", json.array(args_json)),
    ])
  })
  let result = json.object([("prompts", json.array(prompts_json))])
  ok({server: server, response: some(jsonrpc.make_response(req.id, result))})
}

effect fn handle_prompts_get(server: McpServer, req: jsonrpc.JsonRpcRequest) -> Result[{server: McpServer, response: Option[String]}, String] = {
  let name = json.get_string(req.params, "name") ?? ""
  let prompt = server.manifest.prompts |> list.find((p) => p.name == name)
  match prompt {
    none => {
      let resp = jsonrpc.make_error_response(req.id, -32602, "Unknown prompt: '${name}'")
      ok({server: server, response: some(resp)})
    },
    some(_p) => {
      let arguments = json.get(req.params, "arguments") ?? json.object([])
      let args_json = json.stringify(json.object([("prompt", json.from_string(name)), ("arguments", arguments)]))
      let tool_result = dispatch.dispatch_tool(server.config, "_prompt_get", args_json)!
      let content = json.object([
        ("messages", json.array([
          json.object([
            ("role", json.from_string("user")),
            ("content", json.object([
              ("type", json.from_string("text")),
              ("text", json.from_string(tool_result.stdout)),
            ])),
          ]),
        ])),
      ])
      ok({server: server, response: some(jsonrpc.make_response(req.id, content))})
    },
  }
}

// --- Main loop ---

effect fn serve_loop(server: McpServer) -> Result[Unit, String] = {
  let msg = jsonrpc.read_message()!
  match msg {
    none => ok(()),
    some(req) => {
      let result = handle_request(server, req)!
      match result.response {
        some(resp) => {
          jsonrpc.write_message(resp)!
          serve_loop(result.server)
        },
        none => serve_loop(result.server),
      }
    },
  }
}
