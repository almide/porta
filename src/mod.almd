// Porta — WASM agent MCP bridge

import process
import self.cli
import self.engine
import self.ops
import self.build
import self.project

fn has_help_flag(args: List[String]) -> Bool =
  args |> list.any((a) => a == "--help" or a == "-h")

effect fn main() -> Result[Unit, String] = {
  let args = process.args()
  let cmd = list.get(args, 1) ?? "help"

  match cmd {
    "--version" => {
      println("porta 0.1.0")
      ok(())
    },
    "--help" => {
      cli.print_help("")
      ok(())
    },
    "serve" => {
      if has_help_flag(args) then { cli.print_help("serve"); ok(()) }
      else {
        let opts = cli.parse_options(args, 2, cli.default_options())
        if opts.path == "" then { cli.print_help("serve"); ok(()) }
        else engine.serve(opts)
      }
    },
    "run" => {
      if has_help_flag(args) then { cli.print_help("run"); ok(()) }
      else {
        let opts = cli.parse_options(args, 2, cli.default_options())
        if opts.path == "" then { cli.print_help("run"); ok(()) }
        else engine.run_wasm(opts)
      }
    },
    "up" => {
      let rest = list.drop(args, 2)
      let extra_args = if list.get(rest, 0) ?? "" == "--" then list.drop(rest, 1) else rest
      project.porta_up(extra_args)
    },
    "init" => {
      let runtime_type = list.get(args, 2) ?? "native"
      let command = list.get(args, 3) ?? "claude"
      project.porta_init(runtime_type, command)
    },
    "run-native" => {
      if has_help_flag(args) then { cli.print_help("run-native"); ok(()) }
      else {
        let opts = cli.parse_options(args, 2, cli.default_options())
        if opts.path == "" then { cli.print_help("run-native"); ok(()) }
        else engine.run_native(opts)
      }
    },
    "inspect" => {
      if has_help_flag(args) then { cli.print_help("inspect"); ok(()) }
      else {
        let opts = cli.parse_options(args, 2, cli.default_options())
        if opts.path == "" then { cli.print_help("inspect"); ok(()) }
        else engine.inspect(opts.path)
      }
    },
    "validate" => {
      if has_help_flag(args) then { cli.print_help("validate"); ok(()) }
      else {
        let opts = cli.parse_options(args, 2, cli.default_options())
        if opts.path == "" then { cli.print_help("validate"); ok(()) }
        else engine.validate(opts)
      }
    },
    "build" => {
      if has_help_flag(args) then { cli.print_help("build"); ok(()) }
      else {
        let opts = cli.parse_options(args, 2, cli.default_options())
        if opts.path == "" then { cli.print_help("build"); ok(()) }
        else build.build_package(opts)
      }
    },
    "help" => {
      let topic = list.get(args, 2) ?? ""
      cli.print_help(topic)
      ok(())
    },
    "ps" => {
      ops.list_instances()
    },
    "stop" => {
      let id = list.get(args, 2) ?? ""
      if id == "" then { println("usage: porta stop <instance-id>"); ok(()) }
      else ops.signal_instance(id, 15)
    },
    "kill" => {
      let id = list.get(args, 2) ?? ""
      if id == "" then { println("usage: porta kill <instance-id>"); ok(()) }
      else ops.signal_instance(id, 9)
    },
    "logs" => {
      let id = list.get(args, 2) ?? ""
      if id == "" then { println("usage: porta logs <instance-id>"); ok(()) }
      else ops.show_logs(id)
    },
    "rm" => {
      let id = list.get(args, 2) ?? ""
      if id == "" then { println("usage: porta rm <instance-id>"); ok(()) }
      else ops.remove_instance(id)
    },
    "version" => {
      println("porta 0.1.0")
      ok(())
    },
    _ => {
      println("unknown command: ${cmd}")
      println("run 'porta help' for usage")
      ok(())
    },
  }
}
