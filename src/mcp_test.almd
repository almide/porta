import self.mcp
import self.sandbox
import self.dispatch

// --- is_host_allowed ---

test "is_host_allowed: wildcard host matches any host on port" {
  assert(mcp.is_host_allowed("https://api.example.com/path", ["*:443"]))
  assert(mcp.is_host_allowed("https://other.host.com/path", ["*:443"]))
}

test "is_host_allowed: specific host only matches that host" {
  assert(mcp.is_host_allowed("https://api.example.com/path", ["api.example.com:443"]))
  assert(not mcp.is_host_allowed("https://evil.com/path", ["api.example.com:443"]))
}

test "is_host_allowed: wildcard port matches any port" {
  assert(mcp.is_host_allowed("https://api.example.com/path", ["api.example.com:*"]))
  assert(mcp.is_host_allowed("http://api.example.com/path", ["api.example.com:*"]))
}

test "is_host_allowed: http on 443-only denied" {
  assert(not mcp.is_host_allowed("http://api.example.com/path", ["*:443"]))
}

test "is_host_allowed: empty list denies all" {
  assert(not mcp.is_host_allowed("https://api.example.com", []))
}

test "is_host_allowed: multiple entries" {
  assert(mcp.is_host_allowed("https://api.example.com", ["other.com:443", "api.example.com:443"]))
  assert(not mcp.is_host_allowed("https://evil.com", ["other.com:443", "api.example.com:443"]))
}

test "is_host_allowed: explicit port in URL" {
  assert(mcp.is_host_allowed("http://localhost:8080/api", ["localhost:8080"]))
  assert(not mcp.is_host_allowed("http://localhost:9090/api", ["localhost:8080"]))
}

// --- Capability enforcement: porta.exec requires CapExec ---

test "porta.exec: ai-agent profile lacks CapExec" {
  let caps = sandbox.profile_ai_agent()
  assert(not sandbox.has_capability(caps, sandbox.CapExec))
}

test "porta.exec: full profile has CapExec" {
  let caps = sandbox.profile_full()
  assert(sandbox.has_capability(caps, sandbox.CapExec))
}

test "porta.exec: from_manifest exec" {
  let caps = sandbox.from_manifest(["exec"])
  assert(sandbox.has_capability(caps, sandbox.CapExec))
  assert(not sandbox.has_capability(caps, sandbox.CapNet))
}

// --- Capability enforcement: porta.http requires CapNet ---

test "porta.http: ai-agent profile lacks CapNet" {
  let caps = sandbox.profile_ai_agent()
  assert(not sandbox.has_capability(caps, sandbox.CapNet))
}

test "porta.http: worker profile lacks CapNet" {
  let caps = sandbox.profile_worker()
  assert(not sandbox.has_capability(caps, sandbox.CapNet))
}

test "porta.http: from_manifest net" {
  let caps = sandbox.from_manifest(["net"])
  assert(sandbox.has_capability(caps, sandbox.CapNet))
  assert(not sandbox.has_capability(caps, sandbox.CapExec))
}
